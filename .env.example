# Example environment configuration

# Canonical API_TJ base URL.
VITE_API_BASE_URL=http://127.0.0.1:8081/api/v1
# Enable only when the app is deployed on Vercel.
# VITE_ENABLE_SPEED_INSIGHTS=false

# Public Google MyMaps embed URL used in the map view. Replace <MAP_ID> with the actual ID.
VITE_MAPS_URL=https://www.google.com/maps/d/embed?mid=<MAP_ID>
